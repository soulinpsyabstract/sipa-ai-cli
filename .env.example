# SIPA AI CLI · .env для docker-compose
# Скопируй в .env и заполни из /home/sipa/.sipa_env
# cp .env.example .env

# ── SIPA AI backend ───────────────────────────────────────────────────────────
SIPA_AI_BACKEND=https://sipa-ai-backend.soulinpsy.info

# ── Cloudflare tunnel ─────────────────────────────────────────────────────────
SIPA_MAIN_TUNNEL_TOKEN=

# ── AI API keys ───────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
NEBIUS_API_KEY=

# ── SIPA specific ─────────────────────────────────────────────────────────────
SIPA_WEBHOOK_SECRET=
